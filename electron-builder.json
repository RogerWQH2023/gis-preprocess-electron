{
  "appId": "cn.edu.gis.preprocess",
  "productName": "GIS Data Preprocess Teaching",
  "electronDist": "node_modules/electron/dist",
  "afterExtract": "scripts/cleanup-electron-dist.cjs",
  "files": [
    "dist/main/**/*",
    "dist/renderer/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "native-bin",
      "to": "bin",
      "filter": [
        "**/*"
      ]
    }
  ],
  "directories": {
    "output": "dist/app"
  },
  "win": {
    "target": [
      "portable"
    ]
  },
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage",
    "category": "Education"
  }
}
