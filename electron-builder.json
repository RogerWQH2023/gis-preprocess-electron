{
  "appId": "cn.edu.gis.preprocess",
  "productName": "GIS Data Preprocess Teaching",
  "electronDist": "node_modules/electron/dist",
  "afterExtract": "scripts/cleanup-electron-dist.cjs",
  "afterPack": "scripts/verify-packaged-gdal-runtime.mjs",
  "npmRebuild": false,
  "asarUnpack": [
    "package.json",
    "dist/main/tools/bip-to-cogtiff/**/*",
    "node_modules/@petamoriken/float16/**/*",
    "node_modules/xmlbuilder2/**/*",
    "node_modules/@oozcitak/**/*",
    "node_modules/js-yaml/**/*",
    "node_modules/argparse/**/*",
    "node_modules/esprima/**/*",
    "node_modules/sprintf-js/**/*"
  ],
  "files": [
    "dist/main/**/*",
    "dist/renderer/**/*",
    "package.json",
    "node_modules/@petamoriken/float16/**/*",
    "!node_modules/gdal-async/build/**/*",
    "!node_modules/gdal-async/lib/binding/electron-*"
  ],
  "extraResources": [
    {
      "from": "resources/icon.png",
      "to": "icon.png"
    },
    {
      "from": "native-bin",
      "to": "bin",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "node_modules/gdal-async/node_modules",
      "to": "app.asar.unpacked/node_modules/gdal-async/node_modules",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "dist/runtime/gdal-node",
      "to": "gdal-node",
      "filter": [
        "node.exe",
        "LICENSE.node.txt"
      ]
    }
  ],
  "directories": {
    "output": "dist/app",
    "buildResources": "resources"
  },
  "win": {
    "target": [
      "portable"
    ],
    "icon": "icon.ico"
  },
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage",
    "category": "Education"
  }
}
