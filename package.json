{
  "name": "gis-preprocess-electron",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "author": "GIS Teaching Team",
  "description": "教学用 Electron GIS 数据预处理应用基础框架",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "run-p dev:renderer dev:electron",
    "dev:renderer": "vite",
    "dev:main": "run-p dev:renderer dev:electron",
    "dev:electron": "pnpm run transpile:main && wait-on --log --timeout 30000 http://127.0.0.1:5173 && cross-env NODE_ENV=development node scripts/run-electron.mjs .",
    "transpile:main": "tsc --project src/main/tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.app.json && tsc --noEmit --project tsconfig.node.json && tsc --noEmit --project src/main/tsconfig.json",
    "build:renderer": "vite build",
    "build": "pnpm run typecheck && pnpm run transpile:main && pnpm run build:renderer",
    "build:app": "pnpm run build && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win --x64",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "cross-env": "^7.0.3",
    "electron": "^36.5.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.0",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "pnpm": {
    "overrides": {
      "@electron/get": "3.1.0"
    }
  }
}
